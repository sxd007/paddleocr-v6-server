# ═══════════════════════════════════════════════════════════
# PaddleOCR v6 Server — 环境变量模板
# ═══════════════════════════════════════════════════════════
# 使用方式:
#   cp .env.example .env
#   # 编辑 .env 中的值
#   ./setup.sh
# ═══════════════════════════════════════════════════════════

# API 认证密钥（多个用逗号分隔）
API_KEYS=sk-your-secret-key

# 文件上传服务外部访问地址
# 设为客户端（如 Claude Code）可访问的地址
# 部署后替换为实际 IP
PUBLIC_URL_BASE=http://localhost:8091
